{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/schemas/settings.schema.json",
  "model": {
    "name": "agentdeck-deep-default"
  },
  "modelConfigs": {
    "customAliases": {
      "agentdeck-ack": {
        "modelConfig": {
          "model": "gemini-2.5-flash-lite",
          "generateContentConfig": {
            "thinkingConfig": {
              "thinkingBudget": 0
            }
          }
        }
      },
      "agentdeck-deep-default": {
        "modelConfig": {
          "model": "gemini-3-flash-preview",
          "generateContentConfig": {
            "tools": [
              {
                "googleSearch": {}
              }
            ],
            "thinkingConfig": {
              "includeThoughts": true,
              "thinkingLevel": "HIGH"
            }
          }
        }
      },
      "agentdeck-deep-escalate": {
        "modelConfig": {
          "model": "gemini-3-pro-preview",
          "generateContentConfig": {
            "tools": [
              {
                "googleSearch": {}
              }
            ],
            "thinkingConfig": {
              "includeThoughts": true,
              "thinkingLevel": "HIGH"
            }
          }
        }
      }
    }
  }
}
